# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# Admin IDs (comma-separated Telegram user IDs)
ADMIN_IDS=123456789,987654321

# Database
DATABASE_URL=postgresql+asyncpg://otchebot_user:secure_password@postgres:5432/otchebot

# External API Key for pull-mechanism
EXTERNAL_API_KEY=your_secret_api_key_here

# Backup Server Configuration
BACKUP_SERVER=192.168.1.100
BACKUP_SSH_KEY=/path/to/ssh/key
BACKUP_PATH=/backup/otchebot

# Logging level
LOG_LEVEL=INFO

# Anti-flood (seconds between requests from same user)
ANTIFLOOD_INTERVAL=60
